# Dependencies
node_modules/

# Build output
ui/dist/
server/dist/
build/

# Data (local, not committed)
server/data/
*.db
*.db-shm
*.db-wal
*.db-journal

# Session logs (generated per-run)
logs/

# Environment (contains local paths)
.env

# Restart marker (transient, created by /api/restart)
.restart-requested

# Engine build artifacts
engine/acestep.cpp/
engine/build/
engine/deps/
engine/.cache/

# Binaries & compiled objects
*.exe
!Essentia/*.exe
*.dll
*.lib
*.obj
*.o
*.a
*.so
*.dylib
*.pdb
*.ilk
*.exp

# Audio files
*.wav
!noise_samples/*.wav
*.mp3
*.flac
*.ogg
*.aac
*.wma
*.m4a
*.bf16

# Model weights
*.gguf
*.safetensors
*.pt
*.pth
*.onnx

# Test output logs
engine/tests/*.log

# Python
__pycache__/
*.pyc
*.pyo

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/

# Agents & dev tooling (local only)
.agents/
.agent/
.claude/
.gemini/


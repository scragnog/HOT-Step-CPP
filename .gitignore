benchmark-results/
docs/plans/
scratch/

# Release build artifacts (but keep scripts and configs)
release/staging/
release/out/
release/.node-cache/
release/node_modules/
release/package-lock.json
release-staging/
runtime/
*.tar.gz

# Windows NUL device phantom
nul

